/**
 * Umschalter zwischen Tagesimport und Monatsimport.
 */
function processPlanoImport(fileId, importFullMonth) {
  if (importFullMonth === true) {
    return processSelectedMonthFile(fileId);
  }

  return processSelectedFile(fileId);
}

